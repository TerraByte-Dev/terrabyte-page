---
import SocialIcon from './SocialIcon.astro';
const year = new Date().getFullYear();
---
<footer class="hub-footer">
  <div class="hub-socials">
    <SocialIcon href="https://instagram.com/terrabyte.dev" label="Instagram" icon="instagram" />
    <SocialIcon href="https://www.threads.net/@terrabyte.dev" label="Threads" icon="threads" />
  </div>
  <div class="hub-footer-bar">
    <span>© {year} TerraByte Solutions LLC</span>
    <span class="hub-footer-status">uptime 99.97% · synced</span>
  </div>
</footer>

<style>
  .hub-footer {
    margin-top: 36px;
    padding-top: 24px;
    border-top: 1px dashed var(--rule-dim);
  }
  .hub-socials {
    display: flex;
    justify-content: center;
    gap: 12px;
    margin-bottom: 22px;
  }
  .hub-footer-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-faint);
  }
  .hub-footer-status { color: var(--phosphor-dim); }
  @media (max-width: 420px) {
    .hub-footer-bar { justify-content: center; text-align: center; }
  }
</style>
