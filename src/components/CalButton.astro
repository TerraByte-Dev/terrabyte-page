---
interface Props {
  label?: string;
  sub?: string;
  href?: string;
}
const {
  label = 'Book a free call',
  sub = 'free 30-min · cal.com',
  href = 'https://cal.com/terrabyte/consult',
} = Astro.props;

const now = new Date();
const month = now.toLocaleString('en-US', { month: 'short' }).toUpperCase();
const day = now.getDate();
---
<a class="cal-btn" href={href} target="_blank" rel="noopener noreferrer">
  <div class="cal-btn-grid">
    <div class="cal-btn-month">{month}</div>
    <div class="cal-btn-day">{day}</div>
  </div>
  <div class="cal-btn-body">
    <div class="ttl">{label}</div>
    <div class="sub">{sub}</div>
  </div>
</a>
